{
  // Tells Cloudflare Workers to serve this repo as a static site (no server code).
  "name": "elysium-labs-site",
  "compatibility_date": "2025-01-01",
  "assets": {
    "directory": "./",
    "not_found_handling": "404-page"
  },
  "routes": [
    { "pattern": "www.elysiumlabs.co.za/*", "zone_name": "elysiumlabs.co.za" }
  ]
}
